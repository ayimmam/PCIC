# --- Database ---
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/pcic
#
# MongoDB Atlas (team shared — recommended):
# Atlas setup checklist:
#   1. Create a free cluster at https://www.mongodb.com/atlas
#   2. Database Access → create a database user (username + password)
#   3. Network Access → add your IP address (or 0.0.0.0/0 for dev)
#   4. Connect → Drivers → copy the connection string and paste above
#   5. Replace <username>, <password>, <cluster>, <cluster-name> with your values

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/pcic?appName=PCIC

JWT_SECRET=change-this-to-a-random-secret
PORT=5000

# Optional: groups summer submissions (default summer-2026). Change between academic years.
# SUMMER_PROJECT_CYCLE=summer-2026

# Existing MongoDB with old domain strings? From server/: npm run migrate:domains

# Email config (nodemailer) — optional, emails skipped if not set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudinary Upload Platform Config
# Required for persistent uploads on ephemeral free hosts (Render, Railway, etc.)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
